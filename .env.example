# --- GitHub ---
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx        # PAT with repo scope
GITHUB_WEBHOOK_SECRET=changeme               # set the same value in your GitHub webhook config

# --- Groq (free LLM API) ---
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.3-70b-versatile

# --- Supabase ---
SUPABASE_URL=https://xxxxxxxx.supabase.co
SUPABASE_KEY=xxxxxxxxxxxxxxxxxxxx             # service_role key (backend only, never expose to frontend)

# --- App config ---
SIMILARITY_THRESHOLD=0.80                     # cosine similarity to call a failure "recurring"
AUTO_FIX_CONFIDENCE_THRESHOLD=0.85            # min AI confidence to attempt an auto-fix PR
